rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Comprobantes de ejecuciones — auth required
    match /{companyId}/ejecuciones/{ejecucionId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/jpeg|image/png|application/pdf');
      allow delete: if request.auth != null;
    }

    // Documentos media system — auth required
    match /{companyId}/documentos/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('application/pdf|image/jpeg|image/png|image/webp');
      allow delete: if false; // GC scripts only
    }

    // Allow listing ejecuciones folders and files (for diagnostic/fix tools)
    match /{companyId}/ejecuciones/{allPaths=**} {
      allow list: if request.auth != null;
    }

    // Extractos bancarios (PDF) — auth required
    match /{companyId}/extractos/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('application/pdf');
      allow delete: if request.auth != null;
    }

    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
