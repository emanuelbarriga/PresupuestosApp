rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Comprobantes de ejecuciones — desarrollo: sin auth, type & size validated
    match /{companyId}/ejecuciones/{ejecucionId}/{fileName} {
      allow read: if true;
      allow write: if request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/jpeg|image/png|application/pdf');
      allow delete: if true;
    }

    // Allow listing ejecuciones folders and files (for diagnostic/fix tools)
    match /{companyId}/ejecuciones/{allPaths=**} {
      allow list: if true;
    }

    // Extractos bancarios (PDF) — desarrollo: sin auth, tipo & tamaño validados
    match /{companyId}/extractos/{fileName} {
      allow read: if true;
      allow write: if request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('application/pdf');
      allow delete: if true;
    }

    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
