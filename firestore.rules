rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /companies/{companyId} {
      // Subcolecciones por empresa (multi-tenant)
      match /budgets/{doc} { allow read, write: if true; }
      match /ejecuciones/{doc} { allow read, write: if true; }
      match /projects/{doc} { allow read, write: if true; }
      match /clients/{doc} { allow read, write: if true; }
      match /providers/{doc} { allow read, write: if true; }
    }
    // Colecciones globales compartidas
    match /companies/{doc} { allow read: if true; }
    match /stateProject/{doc} { allow read: if true; }
    // Bloquear todo acceso no declarado explícitamente
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
