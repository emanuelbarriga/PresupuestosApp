rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ── Helpers ──
    function isMember(companyId) {
      return request.auth != null &&
        exists(/databases/$(database)/documents/companies/$(companyId)/members/$(request.auth.uid));
    }
    function isAdmin(companyId) {
      return request.auth != null &&
        get(/databases/$(database)/documents/companies/$(companyId)/members/$(request.auth.uid)).data.role == 'admin';
    }

    // ── Collection group rules ──
    // Members — allows users to find their own membership (subscribeUserCompanies)
    match /{path=**}/members/{doc} {
      allow read: if request.auth != null && resource.data.id == request.auth.uid;
    }
    // BudgetLinks — allows subscribeEjecucionesByBudget: collectionGroup('budgetLinks')
    //   where companyId == cId && budgetId == bId
    match /{path=**}/budgetLinks/{doc} {
      allow read: if request.auth != null && isMember(resource.data.companyId);
    }

    // ── Global user profiles (identity agnostic to companies) ──
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }

    // ── Companies ──
    match /companies/{companyId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.name is string;
      allow update: if isMember(companyId) && isAdmin(companyId);
      allow delete: if false;

      // Scoped subcollections — membership required
      match /budgets/{doc} { allow read, write: if isMember(companyId); }
      // Ejecuciones — field-level write validation
      match /ejecuciones/{ejecucionId} {
        allow read: if isMember(companyId);
        allow create: if isMember(companyId);
        allow update: if isMember(companyId) && (
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['descripcion', 'montoEjecutado', 'fechaEjecutado', 'tipo',
                      'projectId', 'projectName',
                      'entityId', 'entityName', 'entityType',
                      'cuentaId', 'cuentaName', 'comprobantes',
                      'archivado', 'updatedAt', 'createdAt',
                      '_linkedDocumentos', '_estadoComprobantes',
                      '_movimientoId', '_extractoId'])
        );
        allow delete: if false;
      }
      match /projects/{doc} { allow read, write: if isMember(companyId); }
      match /cuentasBancarias/{doc} { allow read, write: if isMember(companyId); }
      match /extractos/{doc} { allow read, write: if isMember(companyId); }
      match /settings/{doc} { allow read, write: if isMember(companyId); }

      // Documentos collection — flat media storage
      match /documentos/{doc} {
        allow read: if isMember(companyId);
        allow create: if isMember(companyId)
          && request.resource.data.keys().hasAll(['fileName', 'storagePath', 'mimeType', 'size', 'status', 'uploadedAt'])
          && request.resource.data.status in ['por_clasificar', 'enlazado'];
        // Status transitions:
        // 1. Any transition TO enlazado requires periodo and tipoDocumento as strings
        //    (uses request.resource.data.status — the NEW state — to validate)
        // 2. enlazado → por_clasificar (unlinking) allowed only if ejecucionIds is cleared
        // 3. Internal changes within por_clasificar are always allowed
        allow update: if isMember(companyId) && (
          // 1. New state is enlazado — requires periodo and tipoDocumento strings
          (request.resource.data.status == 'enlazado'
            && request.resource.data.periodo is string
            && request.resource.data.tipoDocumento is string)
          ||
          // 2. enlazado → por_clasificar (unlinking) — requires cleared ejecucionIds
          (resource.data.status == 'enlazado'
            && request.resource.data.status == 'por_clasificar'
            && request.resource.data.ejecucionIds.size() == 0)
          ||
          // 3. Internal changes within por_clasificar
          (resource.data.status == 'por_clasificar'
            && request.resource.data.status == 'por_clasificar')
        );
        allow delete: if false; // GC scripts only
      }

      // BudgetLinks subcollection — same access as ejecuciones
      match /ejecuciones/{ejecucionId}/budgetLinks/{linkId} { allow read, write: if isMember(companyId); }

      // Extractos anidados bajo cuentasBancarias/{accountId}/extractos/
      match /cuentasBancarias/{accountId}/extractos/{extractoId} { allow read, write: if isMember(companyId); }

      // Movimientos subcollection under extractos
      match /cuentasBancarias/{accountId}/extractos/{extractoId}/movimientos/{docId} { allow read, write: if isMember(companyId); }

      // Members subcollection — managed by company admins
      match /members/{doc} {
        allow read: if isMember(companyId);
        allow create: if isAdmin(companyId); // Admins can add members directly
        allow update: if isAdmin(companyId); // Admins can update any member fields
        allow delete: if isAdmin(companyId); // Admins can remove members
      }
    }

    // ── Global Terceros (clients/providers) ──
    // Any authenticated user can read; any authenticated user can write (trusted users).
    match /terceros/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── Invitations ──
    // Admin creates; invited user reads/accepts by email match.
    // Creator, invited user, or company admin can delete.
    match /invitations/{invitationId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.invitedBy ||
        request.auth.token.email == resource.data.email ||
        exists(/databases/$(database)/documents/companies/$(resource.data.companyId)/members/$(request.auth.uid))
      );
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.invitedBy ||
        request.auth.token.email == resource.data.email ||
        exists(/databases/$(database)/documents/companies/$(resource.data.companyId)/members/$(request.auth.uid))
      );
      allow delete: if request.auth != null && (
        request.auth.uid == resource.data.invitedBy ||
        request.auth.token.email == resource.data.email ||
        (exists(/databases/$(database)/documents/companies/$(resource.data.companyId)/members/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/companies/$(resource.data.companyId)/members/$(request.auth.uid)).data.role == 'admin')
      );
    }

    // ── TRANSITIONAL RULES ──
    // These exist at the OLD global path and are kept temporarily while
    // data is migrated under /companies/{companyId}/settings/.
    // TODO: Remove these rules AFTER migration is complete AND all clients
    //       have been updated to read from the company-scoped path.
    match /settings/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /stateProject/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── Catch-all — deny everything not explicitly allowed ──
    match /{document=**} { allow read, write: if false; }
  }
}
